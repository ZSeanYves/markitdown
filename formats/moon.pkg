  "ZSeanYves/markitdown/formats/epub" @fepub,
  "ZSeanYves/markitdown/formats/csv" @fcsv,
  "ZSeanYves/markitdown/formats/docx" @fdocx,
  "ZSeanYves/markitdown/formats/html" @fhtml,
  "ZSeanYves/markitdown/formats/json" @fjson,
  "ZSeanYves/markitdown/formats/markdown" @fmarkdown,
  "ZSeanYves/markitdown/formats/ocr" @focr,
  "ZSeanYves/markitdown/formats/pdf" @fpdf,
  "ZSeanYves/markitdown/formats/pptx" @fpptx,
  "ZSeanYves/markitdown/formats/tsv" @ftsv,
  "ZSeanYves/markitdown/formats/txt" @ftxt,
  "ZSeanYves/markitdown/formats/xml" @fxml,
  "ZSeanYves/markitdown/formats/xlsx" @fxlsx,
  "ZSeanYves/markitdown/formats/yaml" @fyaml,
  "ZSeanYves/markitdown/formats/zip" @fzip,
  "ZSeanYves/markitdown/format_readers/ooxml/shared",
