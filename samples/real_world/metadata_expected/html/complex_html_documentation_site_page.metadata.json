    {
      "block_index": 25,
      "block_type": "paragraph",
      "text": "\n            Production deployment uses a staged rollout. Teams publish a frozen\n            build, update the registry cache, run a validation suite, and only\n            then fan out to scheduled batch jobs.\n          ",
      "origin": {
        "format": "html",
        "source_name": "complex_html_documentation_site_page.html",
        "page": null,
        "slide": null,
        "sheet": null,
        "block_index": 25,
