{
  "output_format": "rag_json",
  "detected_format": "ipynb",
  "parser_mode": "dom_ast_model",
  "convert_mode": "balanced",
  "output_mode": "rag",
  "diagnostics_contains": {
    "parser_name": "ipynb_parser",
    "metrics": {
      "renderer_name": "RagJsonRenderer",
      "effective_mode": "dom_ast_model",
      "ir_input_kind": "document"
    }
  },
  "source_map": "required",
  "chunk_count": {
    "min": 6
  },
  "chunks": [
    {
      "kind": "metadata",
      "text_contains_all": [
        "title: Python 3",
        "description: Jupyter notebook with 2 cells"
      ]
    },
    {
      "kind": "table",
      "source_ref_count": 1,
      "asset_ref_count": 0,
      "text_contains_all": [
        "| Field | Value |",
        "| nbformat | 4 |",
        "| language_info.version | 3.11 |"
      ]
    },
    {
      "kind": "text",
      "source_ref_count": 1,
      "text_contains_all": [
        "[Cell 1 | markdown]"
      ]
    },
    {
      "kind": "text",
      "source_ref_count": 1,
      "text_contains_all": [
        "Body text.",
        "[Cell 2 | code | execution=7]"
      ]
    },
    {
      "kind": "code",
      "source_ref_count": 1,
      "text_contains_all": [
        "print('hello')"
      ]
    },
    {
      "kind": "text",
      "source_ref_count": 1,
      "text_contains_all": [
        "[Output 2.1 | stream | stdout]"
      ]
    }
  ]
}
