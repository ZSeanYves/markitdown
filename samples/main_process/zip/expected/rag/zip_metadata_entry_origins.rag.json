{
  "output_format": "rag_json",
  "detected_format": "zip",
  "parser_mode": "container_recursive",
  "convert_mode": "balanced",
  "output_mode": "rag",
  "diagnostics_contains": {
    "parser_name": "zip_container_parser",
    "metrics": {
      "renderer_name": "RagJsonRenderer"
    }
  },
  "source_map": "required",
  "chunk_count": {
    "min": 3
  },
  "chunks": [
    {
      "kind": "table",
      "heading_path": [
        "data/info.json"
      ],
      "source_ref_count": 10,
      "asset_ref_count": 0,
      "text_contains_all": [
        "| Key | Value |\n| name | Ada |\n| team | Infra |"
      ],
      "location_contains": {
        "cell_ranges": [
          "R1C1:R1C2",
          "R1C1",
          "R1C2",
          "R2C1:R2C2",
          "R2C1",
          "R2C2",
          "R3C1:R3C2",
          "R3C1",
          "R3C2"
        ],
        "container_paths": [
          "zip_metadata_entry_origins.zip"
        ],
        "entry_paths": [
          "data/info.json"
        ]
      }
    },
    {
      "kind": "text",
      "heading_path": [
        "Notes"
      ],
      "source_ref_count": 1,
      "asset_ref_count": 0,
      "text_contains_all": [
        "Archive level note."
      ],
      "location_contains": {
        "container_paths": [
          "zip_metadata_entry_origins.zip"
        ],
        "entry_paths": [
          "notes/readme.md"
        ]
      }
    },
    {
      "kind": "table",
      "heading_path": [
        "tables/people.csv"
      ],
      "source_ref_count": 10,
      "asset_ref_count": 0,
      "text_contains_all": [
        "| Name | Role |\n| Ada | Engineer |\n| Bob | Designer |"
      ],
      "location_contains": {
        "cell_ranges": [
          "R1C1:R3C2",
          "R1C1:R1C2",
          "R1C1",
          "R1C2",
          "R2C1:R2C2",
          "R2C1",
          "R2C2",
          "R3C1:R3C2",
          "R3C1",
          "R3C2"
        ],
        "container_paths": [
          "zip_metadata_entry_origins.zip"
        ],
        "entry_paths": [
          "tables/people.csv"
        ]
      }
    }
  ]
}
