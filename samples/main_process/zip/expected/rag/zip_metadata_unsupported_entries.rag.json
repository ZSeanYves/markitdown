{
  "output_format": "rag_json",
  "detected_format": "zip",
  "parser_mode": "container_recursive",
  "convert_mode": "balanced",
  "output_mode": "rag",
  "diagnostics_contains": {
    "parser_name": "zip_container_parser",
    "metrics": {
      "renderer_name": "RagJsonRenderer"
    }
  },
  "source_map": "required",
  "chunk_count": {
    "min": 3
  },
  "chunks": [
    {
      "kind": "text",
      "heading_path": [
        "Archive Notes"
      ],
      "source_ref_count": 1,
      "asset_ref_count": 0,
      "text_contains_all": [
        "Body."
      ],
      "location_contains": {
        "container_paths": [
          "zip_metadata_unsupported_entries.zip"
        ],
        "entry_paths": [
          "notes/readme.md"
        ]
      }
    },
    {
      "kind": "text",
      "heading_path": [
        "unsupported/blob.bin"
      ],
      "source_ref_count": 1,
      "asset_ref_count": 0,
      "text_contains_all": [
        "> Skipped: unsupported file type: bin"
      ],
      "location_contains": {
        "container_paths": [
          "zip_metadata_unsupported_entries.zip"
        ],
        "entry_paths": [
          "unsupported/blob.bin"
        ]
      }
    },
    {
      "kind": "text",
      "heading_path": [
        "unsupported/raw.jpg"
      ],
      "source_ref_count": 1,
      "asset_ref_count": 0,
      "text_contains_all": [
        "> Skipped: unsupported file type: jpg"
      ],
      "location_contains": {
        "container_paths": [
          "zip_metadata_unsupported_entries.zip"
        ],
        "entry_paths": [
          "unsupported/raw.jpg"
        ]
      }
    }
  ]
}
