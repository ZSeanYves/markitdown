{
  "output_format": "rag_json",
  "detected_format": "asciidoc",
  "parser_mode": "dom_ast_model",
  "convert_mode": "balanced",
  "output_mode": "rag",
  "diagnostics_contains": {
    "parser_name": "asciidoc_parser",
    "metrics": {
      "renderer_name": "RagJsonRenderer",
      "effective_mode": "dom_ast_model",
      "ir_input_kind": "document",
      "table_count": "1",
      "blockquote_count": "1",
      "raw_count": "0"
    }
  },
  "source_map": "null",
  "chunk_count": {
    "min": 2
  },
  "chunks": [
    {
      "kind": "table",
      "text_contains_all": [
        "| Attribute | Value |",
        "| idprefix |",
        "| source-language | ruby |"
      ]
    },
    {
      "kind": "text",
      "text_contains_all": [
        "> QUOTE - Ada Lovelace",
        "> That brain of mine.",
        "Include: shared.adoc",
        "leveloffset=+1"
      ]
    }
  ]
}
