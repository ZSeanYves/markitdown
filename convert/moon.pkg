  "ZSeanYves/markitdown/formats/yaml" @fyaml,
  "ZSeanYves/markitdown/format_readers/html" @dhtml,
  "ZSeanYves/markitdown/format_readers/json" @djson,
  "ZSeanYves/markitdown/format_readers/markdown" @dmd,
  "ZSeanYves/markitdown/format_readers/ooxml/package" @ox,
  "ZSeanYves/markitdown/formats/xlsx" @dxlsx,
  "ZSeanYves/markitdown/format_readers/xml" @dxml,
  "ZSeanYves/markitdown/format_readers/yaml" @dyaml,
