///|
fn hex_digit_value(ch : Char) -> Int {
  if ch >= '0' && ch <= '9' {
    ch.to_int() - '0'.to_int()
  } else if ch >= 'a' && ch <= 'f' {
    ch.to_int() - 'a'.to_int() + 10
  } else if ch >= 'A' && ch <= 'F' {
    ch.to_int() - 'A'.to_int() + 10
  } else {
    0
  }
}

///|
fn hex_u16(chars : Array[Char], start : Int) -> Int {
  (hex_digit_value(chars[start]) << 12) |
  (hex_digit_value(chars[start + 1]) << 8) |
  (hex_digit_value(chars[start + 2]) << 4) |
  hex_digit_value(chars[start + 3])
}

///|
fn build_shift_jis_map() -> Map[Int, Int] {
  let chars = shift_jis_blob.to_array()
  let pair_count = chars.length() / 8
  let pairs : Array[(Int, Int)] = Array::new(capacity=pair_count)
  let mut offset = 0
  while offset < chars.length() {
    let code = hex_u16(chars, offset)
    let cp = hex_u16(chars, offset + 4)
    pairs.push((code, cp))
    offset = offset + 8
  }
  Map::from_array(pairs)
}

///|
let shift_jis_map : Map[Int, Int] = build_shift_jis_map()

///|
fn codepoints_of_shift_jis(bytes : Array[Int]) -> Array[Int] {
  let out = Array::new()
  let mut i = 0
  while i < bytes.length() {
    let b = bytes[i]
    if b <= 0x7f {
      out.push(b)
      i = i + 1
      continue
    }
    if b >= 0xa1 && b <= 0xdf {
      out.push(0xff61 + (b - 0xa1))
      i = i + 1
      continue
    }
    if (b >= 0x81 && b <= 0x9f) || (b >= 0xe0 && b <= 0xef) {
      if i + 1 >= bytes.length() {
        out.push(0xfffd)
        break
      }
      let b2 = bytes[i + 1]
      let code = (b << 8) | b2
      match shift_jis_map.get(code) {
        Some(cp) => out.push(cp)
        None => out.push(0xfffd)
      }
      i = i + 2
      continue
    }
    out.push(0xfffd)
    i = i + 1
  }
  out
}
