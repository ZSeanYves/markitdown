///|
let cp932_explicit_delta_map : Map[Int, Int] = build_cp932_explicit_delta_map()

///|
fn build_cp932_explicit_delta_map() -> Map[Int, Int] {
  let chars = cp932_explicit_delta_blob.to_array()
  let pairs : Array[(Int, Int)] = []
  let mut i = 0
  while i + 7 < chars.length() {
    let code = parse_cp932_hex_u16(chars, i)
    let cp = parse_cp932_hex_u16(chars, i + 4)
    pairs.push((code, cp))
    i += 8
  }
  Map::from_array(pairs)
}

///|
fn parse_cp932_hex_u16(chars : Array[Char], offset : Int) -> Int {
  let mut out = 0
  let mut i = 0
  while i < 4 {
    out = (out << 4) | cp932_hex_nibble(chars[offset + i])
    i += 1
  }
  out
}

///|
fn cp932_hex_nibble(ch : Char) -> Int {
  if ch >= '0' && ch <= '9' {
    return ch.to_int() - '0'.to_int()
  }
  if ch >= 'a' && ch <= 'f' {
    return 10 + ch.to_int() - 'a'.to_int()
  }
  if ch >= 'A' && ch <= 'F' {
    return 10 + ch.to_int() - 'A'.to_int()
  }
  0
}

///|
fn is_cp932_trail_byte(byte : Int) -> Bool {
  (byte >= 0x40 && byte <= 0x7E) || (byte >= 0x80 && byte <= 0xFC)
}

///|
fn cp932_private_use_codepoint(code : Int) -> Int? {
  let lead = (code >> 8) & 0xFF
  let trail = code & 0xFF
  if lead < 0xF0 || lead > 0xF9 || !is_cp932_trail_byte(trail) {
    return None
  }
  let trail_index = if trail <= 0x7E {
    trail - 0x40
  } else {
    63 + (trail - 0x80)
  }
  Some(0xE000 + (lead - 0xF0) * 188 + trail_index)
}

///|
fn cp932_codepoint_of_pair(code : Int) -> Int? {
  match cp932_explicit_delta_map.get(code) {
    Some(cp) => return Some(cp)
    None => ()
  }

  match cp932_private_use_codepoint(code) {
    Some(cp) => return Some(cp)
    None => ()
  }

  let b1 = (code >> 8) & 0xFF
  let b2 = code & 0xFF
  let cps = codepoints_of_shift_jis([b1, b2])
  if cps.length() != 1 || cps[0] == 0xFFFD {
    return None
  }
  Some(cps[0])
}

///|
fn string_of_codepoints(codepoints : Array[Int]) -> String? {
  let chars : Array[Char] = []
  for cp in codepoints {
    if cp < 0 || cp > 0x10FFFF || (cp >= 0xD800 && cp <= 0xDFFF) {
      return None
    }
    chars.push(Int::unsafe_to_char(cp))
  }
  Some(String::from_array(chars))
}

///|
fn decode_delimited_cp932_text(bytes : Bytes) -> String? {
  let raw = bytes.to_array()
  let cps : Array[Int] = []
  let mut i = 0
  while i < raw.length() {
    let b = raw[i].to_int()
    if b <= 0x7F {
      cps.push(b)
      i += 1
      continue
    }
    if b >= 0xA1 && b <= 0xDF {
      cps.push(0xFF61 + (b - 0xA1))
      i += 1
      continue
    }
    if (b >= 0x81 && b <= 0x9F) || (b >= 0xE0 && b <= 0xFC) {
      if i + 1 >= raw.length() {
        return None
      }
      let b2 = raw[i + 1].to_int()
      if !is_cp932_trail_byte(b2) {
        return None
      }
      let code = (b << 8) | b2
      match cp932_codepoint_of_pair(code) {
        Some(cp) => cps.push(cp)
        None => return None
      }
      i += 2
      continue
    }
    return None
  }
  string_of_codepoints(cps)
}
