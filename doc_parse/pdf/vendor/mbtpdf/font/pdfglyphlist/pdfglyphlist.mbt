///|
fn glyphlist_hex_digit_value(ch : Char) -> Int {
  if ch >= '0' && ch <= '9' {
    ch.to_int() - '0'.to_int()
  } else if ch >= 'a' && ch <= 'f' {
    ch.to_int() - 'a'.to_int() + 10
  } else if ch >= 'A' && ch <= 'F' {
    ch.to_int() - 'A'.to_int() + 10
  } else {
    0
  }
}

///|
fn decode_glyphlist_src() -> Array[Byte] {
  let chars = glyphlist_src_hex.to_array()
  let out : Array[Byte] = Array::new(capacity=chars.length() / 2)
  let mut i = 0
  while i < chars.length() {
    let hi = glyphlist_hex_digit_value(chars[i])
    let lo = glyphlist_hex_digit_value(chars[i + 1])
    out.push(((hi << 4) | lo).to_byte())
    i = i + 2
  }
  out
}

///|
let glyphlist_src_data : Array[Byte] = decode_glyphlist_src()

///|
pub fn PdfGlyphList::glyphlist_src(_self : PdfGlyphList) -> Array[Byte] {
  glyphlist_src_data.copy()
}

