///|
/// Unicode 兼容字符归一化。
/// 这里只做“字符级兼容映射”，不做词边界恢复。
///
/// 目标：
/// - ligature
/// - CJK compatibility glyph
/// - 全角/零宽/nbsp
/// - 常见兼容标点
///
/// 不处理：
/// - con firm -> confirm
/// - This is -> Thisis / This is
/// - inter national -> international
/// 这些属于词边界恢复，不属于字符映射。
pub fn normalize_unicode_compat(text : String) -> String {
  let mut out = ""
  for ch in text {
    out = out + normalize_unicode_compat_char(ch)
  }
  out
}

///|
fn normalize_unicode_compat_char(ch : Char) -> String {
  match ch {
    // ---------- spaces / controls ----------
    '\r' => "\n"
    '\n' => " "
    '\t' => " "
    '\u{00A0}' => " " // NBSP
    '\u{1680}' => " "
    '\u{2000}' => " "
    '\u{2001}' => " "
    '\u{2002}' => " "
    '\u{2003}' => " "
    '\u{2004}' => " "
    '\u{2005}' => " "
    '\u{2006}' => " "
    '\u{2007}' => " "
    '\u{2008}' => " "
    '\u{2009}' => " "
    '\u{200A}' => " "
    '\u{202F}' => " "
    '\u{205F}' => " "
    '\u{3000}' => " "
    '\u{200B}' => "" // zero-width
    '\u{200C}' => ""
    '\u{200D}' => ""
    '\u{2060}' => ""

    // ---------- common ligatures ----------
    'ﬀ' => "ff"
    'ﬁ' => "fi"
    'ﬂ' => "fl"
    'ﬃ' => "ffi"
    'ﬄ' => "ffl"
    'ﬅ' => "ft"
    'ﬆ' => "st"

    // ---------- common punctuation compatibility ----------
    '“' => "\""
    '”' => "\""
    '„' => "\""
    '‟' => "\""
    '‘' => "'"
    '’' => "'"
    '‚' => "'"
    '‛' => "'"
    '—' => "-"
    '–' => "-"
    '‒' => "-"
    '―' => "-"
    '…' => "..."
    '﹣' => "-"
    '－' => "-"

    // ---------- CJK compatibility / radicals often seen in PDF extraction ----------
    '⼀' => "一"
    '⼁' => "丨"
    '⼂' => "丶"
    '⼃' => "丿"
    '⼄' => "乙"
    '⼅' => "亅"
    '⼆' => "二"
    '⼈' => "人"
    '⼉' => "儿"
    '⼊' => "入"
    '⼋' => "八"
    '⼌' => "冂"
    '⼍' => "冖"
    '⼎' => "冫"
    '⼏' => "几"
    '⼐' => "凵"
    '⼑' => "刀"
    '⼒' => "力"
    '⼓' => "勹"
    '⼔' => "匕"
    '⼕' => "匚"
    '⼖' => "匸"
    '⼗' => "十"
    '⼘' => "卜"
    '⼙' => "卩"
    '⼚' => "厂"
    '⼛' => "厶"
    '⼜' => "又"
    '⼝' => "口"
    '⼞' => "囗"
    '⼟' => "土"
    '⼠' => "士"
    '⼡' => "夂"
    '⼢' => "夊"
    '⼣' => "夕"
    '⼤' => "大"
    '⼥' => "女"
    '⼦' => "子"
    '⼧' => "宀"
    '⼨' => "寸"
    '⼩' => "小"
    '⼪' => "尢"
