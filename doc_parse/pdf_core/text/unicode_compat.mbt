    '⽯' => "石"
    '⽰' => "示"
    '⽱' => "禸"
    '⽲' => "禾"
    '⽳' => "穴"
    '⽴' => "立"
    '⽵' => "竹"
    '⽶' => "米"
    '⽷' => "糸"
    '⽸' => "缶"
    '⽹' => "网"
    '⽺' => "羊"
    '⽻' => "羽"
    '⽼' => "老"
