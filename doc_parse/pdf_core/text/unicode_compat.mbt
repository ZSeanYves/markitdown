    '⼷' => "弋"
    '⼸' => "弓"
    '⼹' => "彐"
    '⼺' => "彡"
    '⼻' => "彳"
    '⼼' => "心"
    '⼽' => "戈"
    '⼾' => "户"
    '⼿' => "手"
    '⽀' => "支"
    '⻅' => "见"
    '⽁' => "攴"
    '⽂' => "文"
    '⽃' => "斗"
