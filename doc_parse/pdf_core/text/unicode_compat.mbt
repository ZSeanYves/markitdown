    '⾴' => "頁"
    '⾵' => "風"
    '⾶' => "飛"
    '⾷' => "食"
    '⾸' => "首"
    '⾹' => "香"
    '⾺' => "馬"
    '⾻' => "骨"
    '⾼' => "高"
    '⾽' => "髟"
    '⾾' => "鬥"
    '⾿' => "鬯"
    '⿀' => "鬲"
    '⿁' => "鬼"
    '⿂' => "魚"
    '⿃' => "鳥"
    '⿄' => "鹵"
    '⿅' => "鹿"
    '⿆' => "麥"
    '⿇' => "麻"
    '⿈' => "黃"
    '⿉' => "黍"
    '⿊' => "黑"
    '⿋' => "黹"
    '⿌' => "黽"
    '⿍' => "鼎"
    '⿎' => "鼓"
    '⿏' => "鼠"
    '⿐' => "鼻"
    '⿑' => "齊"
    '⿒' => "齒"
    '⿓' => "龍"
    '⿔' => "龜"
    '⿕' => "龠"
    _ => ch.to_string()
  }
}
