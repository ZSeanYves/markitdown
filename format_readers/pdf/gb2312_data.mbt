///|
let pdf_native_gb2312_entry_count : Int = 8178

///|
let pdf_native_gb2312_blob : @lazy.Lazy[Bytes] = Lazy(() => {
  pdf_decode_base64_zlib_blob(
    pdf_native_gb2312_blob_base64, "pdf_native_gb2312",
  )
})

///|
fn pdf_native_gb2312_lookup_codepoint(lead : Int, trail : Int) -> Int? {
  if lead < 0xA1 || lead > 0xF7 || trail < 0xA1 || trail > 0xFE {
    return None
  }
  let index = (lead - 0xA1) * 94 + (trail - 0xA1)
  if index < 0 || index >= pdf_native_gb2312_entry_count {
    return None
  }
  let codepoint = pdf_blob_u16_at_index(pdf_native_gb2312_blob.force(), index)
  if codepoint <= 0 {
    None
  } else {
    Some(codepoint)
  }
}
