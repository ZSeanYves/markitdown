///|
fn pdf_font_encoding_strip_leading_slash(name : String) -> String {
  if name.has_prefix("/") {
    name[1:].to_owned()
  } else {
    name
  }
}

///|
fn pdf_font_encoding_string_from_codepoints(codepoints : Array[Int]) -> String {
  let chars : Array[Char] = []
  for codepoint in codepoints {
    chars.push(Int::unsafe_to_char(codepoint))
  }
  String::from_array(chars)
}

///|
fn pdf_font_parse_uni_glyph_name(name : String) -> String? {
  let normalized = pdf_font_encoding_strip_leading_slash(name)
  if normalized.has_prefix("uni") && normalized.length() > 3 {
    let hex = normalized[3:].to_owned()
    if hex.length() == 0 || hex.length() % 4 != 0 {
      return None
    }
    let codepoints : Array[Int] = []
    let mut index = 0
    while index + 4 <= hex.length() {
      match pdf_parse_hex_int(hex[index:index + 4].to_owned()) {
        Some(value) => codepoints.push(value)
        None => return None
      }
      index += 4
    }
    return Some(pdf_font_encoding_string_from_codepoints(codepoints))
  }
  if normalized.has_prefix("u") && normalized.length() >= 5 {
    let hex = normalized[1:].to_owned()
    match pdf_parse_hex_int(hex) {
      Some(value) if value >= 0 && value <= 0x10FFFF =>
        Some(pdf_font_encoding_string_from_codepoints([value]))
      _ => None
    }
  } else if normalized.length() == 1 {
    Some(normalized)
  } else {
    None
  }
}

///|
fn pdf_font_glyph_name_to_unicode(name : String) -> String? {
  let normalized = pdf_font_encoding_strip_leading_slash(name)
  let key = "/" + normalized
  for pair in pdf_font_name_to_pdf_pairs {
    if pair.0 == key {
      return Some(pdf_font_encoding_string_from_codepoints([pair.1]))
    }
  }
  for pair in pdf_font_symbol_unicode_pairs {
    if pair.0 == key {
      return Some(pdf_font_encoding_string_from_codepoints([pair.1]))
    }
  }
  for pair in pdf_font_dingbat_unicode_pairs {
    if pair.0 == key {
      return Some(pdf_font_encoding_string_from_codepoints(pair.1))
    }
  }
  pdf_font_parse_uni_glyph_name(normalized)
}

///|
fn pdf_font_encoding_pairs_for_name(
  encoding_name : String,
) -> Array[(String, Int)] {
  match encoding_name {
    "StandardEncoding" => pdf_font_standard_encoding_pairs
    "WinAnsiEncoding" => pdf_font_winansi_encoding_pairs
    "MacRomanEncoding" => pdf_font_macroman_encoding_pairs
    "Symbol" => pdf_font_symbol_encoding_pairs
    "ZapfDingbats" => pdf_font_dingbats_encoding_pairs
    _ => []
  }
}

///|
fn pdf_font_base_encoding_code_to_glyph_map(
  encoding_name : String,
) -> Map[Int, String] {
  let mapping : Map[Int, String] = Map([])
  for pair in pdf_font_encoding_pairs_for_name(encoding_name) {
    mapping.set(pair.1, pdf_font_encoding_strip_leading_slash(pair.0))
  }
  mapping
}

